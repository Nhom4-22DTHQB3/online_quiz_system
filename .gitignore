# 1. Dependency Directories
node_modules/
client/node_modules/

# 2. Environment Variables & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. Build Outputs and Compiled Assets
client/dist/
client/build/

# 4. Diagnostic Logs and Debugging Files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 5. Operating System Specific Files
.DS_Store
Thumbs.db
